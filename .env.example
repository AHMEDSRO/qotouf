# ============================================
# قطوف — متغيرات البيئة
# انسخ الملف ده إلى .env.local واملأ القيم
# ============================================

# مصدر البيانات: mock (افتراضي، الفاز 1 — ملف JSON محلي في .data/) | supabase (لاحقًا)
DATA_SOURCE=mock

# --- لاحقًا: Supabase (Project Settings -> API) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- لاحقًا: Stripe (بانتظار الرخصة التجارية) ---
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# رقم واتساب قطوف بصيغة دولية من غير + أو مسافات (مثال: 971501234567)
NEXT_PUBLIC_WHATSAPP_NUMBER=971500000000
